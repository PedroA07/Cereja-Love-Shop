# ============================================================
# Cereja Love Shop — variáveis de ambiente (exemplo)
# Copie para .env e preencha. NUNCA commite segredos reais (§8).
# ============================================================

NODE_ENV=development

# --- API ---
API_PORT=3333
API_URL=http://localhost:3333
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# --- Front (Next.js) — exposto ao browser ---
# Base da API para a loja. Na Vercel, defina com a URL pública da API.
NEXT_PUBLIC_API_URL=http://localhost:3333/api/v1

# Admin (staff): seed do primeiro administrador (usado por db:seed)
SEED_ADMIN_EMAIL=admin@cerejaloveshop.local
SEED_ADMIN_PASSWORD=troque-esta-senha

# --- PostgreSQL ---
# Requer extensões: citext, pgcrypto (habilitadas na migração inicial)
DATABASE_URL=postgresql://cereja:cereja@localhost:5432/cereja?schema=public

# --- Redis (sessão / cache / filas BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Meilisearch ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev_meili_master_key_change_me

# --- Object storage (MinIO em dev, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=cereja-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Auth / JWT ---
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_chars_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_chars_long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# --- Criptografia de coluna (PII: CPF, birth_date, telefone) — §1.2/§8 ---
# Chave AES-256-GCM em base64 (32 bytes). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
COLUMN_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTES

# --- Discrição (§1.2 / §8) ---
# Descritor neutro que aparece na fatura do cartão e no remetente do pacote.
BILLING_STATEMENT_DESCRIPTOR=CLS*COMPRAS
DISCREET_SENDER_NAME=CLS Distribuidora
