// Cereja Love Shop — schema Prisma (fonte: ESPECIFICACAO-PROJETO.md §5)
// Regras gerais: UUID como id público; dinheiro em centavos (BigInt);
// TIMESTAMPTZ; PII sensível (CPF, birth_date, telefone) em colunas BYTEA
// criptografadas na aplicação; soft-delete onde indicado.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, pgcrypto]
}

// =========================== IDENTITY ===========================

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique @db.Citext
  name           String
  cpfEncrypted   Bytes     @map("cpf_encrypted")
  birthDate      DateTime  @map("birth_date") @db.Date // validação 18+ na aplicação
  phoneEncrypted Bytes?    @map("phone_encrypted")
  status         String    @default("pending_verification") // pending_verification|active|suspended
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  credentials       AuthCredential?
  addresses         UserAddress[]
  consents          UserConsent[]
  cart              Cart?
  orders            Order[]
  reviews           Review[]
  wishlists         Wishlist[]
  couponRedemptions CouponRedemption[]

  @@map("users")
}

model AuthCredential {
  userId       String   @id @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash") // Argon2id
  totpSecret   Bytes?   @map("totp_secret")
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}

model UserAddress {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String? @map("user_id") @db.Uuid
  zipCode    String  @map("zip_code")
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String? @db.Char(2)
  isDefault  Boolean @default(false) @map("is_default")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model UserConsent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  purpose       String // marketing | profiling | analytics
  granted       Boolean
  policyVersion String   @map("policy_version")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_consents")
}

// Identidades internas — SEPARADAS das de clientes; 2FA obrigatório (§6.8)
model StaffUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.Citext
  name         String
  passwordHash String   @map("password_hash")
  totpSecret   Bytes    @map("totp_secret")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  roles          StaffUserRole[]
  stockMovements StockMovement[]
  couponsCreated Coupon[]

  @@map("staff_users")
}

model Permission {
  id   Int    @id @default(autoincrement())
  code String @unique // 'product:create'

  roles RolePermission[]

  @@map("permissions")
}

model StaffRole {
  id   Int    @id @default(autoincrement())
  name String @unique

  permissions RolePermission[]
  staff       StaffUserRole[]

  @@map("staff_roles")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       StaffRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model StaffUserRole {
  staffId String @map("staff_id") @db.Uuid
  roleId  Int    @map("role_id")

  staff StaffUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  role  StaffRole @relation(fields: [roleId], references: [id])

  @@id([staffId, roleId])
  @@map("staff_user_roles")
}

// =========================== CATALOG ===========================

model Category {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId String? @map("parent_id") @db.Uuid
  name     String
  slug     String  @unique

  parent   Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]    @relation("CategoryTree")
  scopes   CouponScope[]

  @@map("categories")
}

model Product {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String   @unique
  description      String?
  brand            String?
  attributes       Json     @default("{}") // material, dimensões, voltagem...
  isSensitiveMedia Boolean  @default(true) @map("is_sensitive_media") // thumbnail discreto por padrão
  status           String   @default("draft") // draft|review|published|archived
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  variants      ProductVariant[]
  media         ProductMedia[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  scopes        CouponScope[]

  @@map("products")
}

model ProductVariant {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  sku            String  @unique
  options        Json    @default("{}")
  priceCents     BigInt  @map("price_cents")
  salePriceCents BigInt? @map("sale_price_cents")
  barcode        String?

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory      Inventory?
  stockMovements StockMovement[]
  cartItems      CartItem[]
  orderItems     OrderItem[]

  @@index([productId], map: "idx_variant_product")
  @@map("product_variants")
}

model Inventory {
  variantId String @id @map("variant_id") @db.Uuid
  quantity  Int    @default(0)
  reserved  Int    @default(0)
  version   Int    @default(0) // lock otimista (§6.2)

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

// Ledger imutável de estoque (§6.2): nunca sobrescrever quantidade "na mão".
model StockMovement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  type      String // entrada|saida|ajuste|reserva|liberacao|transferencia
  quantity  Int
  reason    String?
  orderId   String?  @map("order_id") @db.Uuid
  staffId   String?  @map("staff_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  variant ProductVariant @relation(fields: [variantId], references: [id])
  staff   StaffUser?     @relation(fields: [staffId], references: [id])

  @@index([variantId, createdAt], map: "idx_stock_mov_variant")
  @@map("stock_movements")
}

model ProductMedia {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String @map("product_id") @db.Uuid
  url       String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_media")
}

// =========================== CART / ORDERS ===========================

model Cart {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String @map("cart_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity  Int

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

model Order {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String?  @map("user_id") @db.Uuid // NULL em convidado
  guestEmail       String?  @map("guest_email") @db.Citext
  status           String   @default("created") // ver máquina de estados (§7)
  subtotalCents    BigInt   @map("subtotal_cents")
  shippingCents    BigInt   @map("shipping_cents")
  discountCents    BigInt   @default(0) @map("discount_cents")
  totalCents       BigInt   @map("total_cents")
  shippingSnapshot Json?    @map("shipping_snapshot")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User?                @relation(fields: [userId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  payments          Payment[]
  couponRedemptions CouponRedemption[]

  @@index([userId], map: "idx_orders_user")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String  @map("order_id") @db.Uuid
  variantId      String? @map("variant_id") @db.Uuid
  nameSnapshot   String  @map("name_snapshot")
  unitPriceCents BigInt  @map("unit_price_cents")
  quantity       Int

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  status    String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

// =========================== PAYMENTS ===========================

model Payment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId        String   @map("order_id") @db.Uuid
  method         String // pix|boleto|credit_card
  status         String   @default("pending") // pending|authorized|paid|failed|refunded
  gatewayToken   String?  @map("gateway_token") // token do gateway (nunca o cartão)
  amountCents    BigInt   @map("amount_cents")
  installments   Int      @default(1)
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// =========================== COUPONS ===========================

model Coupon {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String?   @unique
  name              String?
  discountType      String    @map("discount_type") // percent|fixed|free_shipping
  value             BigInt    @default(0) // % (ex.:15) ou centavos, conforme tipo
  maxDiscountCents  BigInt?   @map("max_discount_cents")
  minOrderCents     BigInt?   @map("min_order_cents")
  scope             String    @default("cart") // cart|products|categories
  firstPurchaseOnly Boolean   @default(false) @map("first_purchase_only")
  combinable        Boolean   @default(false)
  usageLimit        Int?      @map("usage_limit")
  usageLimitPerUser Int       @default(1) @map("usage_limit_per_user")
  usedCount         Int       @default(0) @map("used_count") // contador atômico (§6.7)
  validFrom         DateTime? @map("valid_from") @db.Timestamptz(6)
  validUntil        DateTime? @map("valid_until") @db.Timestamptz(6)
  isActive          Boolean   @default(true) @map("is_active")
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  createdByStaff StaffUser?         @relation(fields: [createdBy], references: [id])
  scopes         CouponScope[]
  redemptions    CouponRedemption[]

  @@map("coupons")
}

// DDL §5 não define PK; Prisma exige identificador — adicionamos `id` sintético.
model CouponScope {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId   String  @map("coupon_id") @db.Uuid
  productId  String? @map("product_id") @db.Uuid
  categoryId String? @map("category_id") @db.Uuid

  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("coupon_scopes")
}

model CouponRedemption {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId      String   @map("coupon_id") @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  guestEmail    String?  @map("guest_email") @db.Citext
  discountCents BigInt   @map("discount_cents")
  redeemedAt    DateTime @default(now()) @map("redeemed_at") @db.Timestamptz(6)

  coupon Coupon @relation(fields: [couponId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_redemptions_user")
  @@index([guestEmail], map: "idx_redemptions_email")
  @@map("coupon_redemptions")
}

// =========================== ENGAGEMENT / AUDIT ===========================

model Review {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  rating    Int      @db.SmallInt
  comment   String?
  status    String   @default("pending") // moderação obrigatória (§6.8)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId], map: "idx_reviews_product")
  @@map("reviews")
}

model Wishlist {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @map("user_id") @db.Uuid

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  wishlistId String @map("wishlist_id") @db.Uuid
  productId  String @map("product_id") @db.Uuid

  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@id([wishlistId, productId])
  @@map("wishlist_items")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  action    String
  entity    String?
  entityId  String?  @map("entity_id") @db.Uuid
  metadata  Json? // sem PII/cartão (§8)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_logs")
}
